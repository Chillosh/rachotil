Screen {
    background: #1a1a1a;
}

Log {
    height: 1fr;
    background: black;
    color: lightgreen;
}

#sshInput {
    dock: bottom;
}

#stats_label {
    content-align: center middle;
    height: 1fr;
    width: 100%;
    color: cyan;
}

MenuScreen {
    align: center middle;
    background: black 50%;
}

#main_menu {
    width: 50%;
    height: auto;
    max-height: 15;
    border: double $accent;
    background: $surface;
}